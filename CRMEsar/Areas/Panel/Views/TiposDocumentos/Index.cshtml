@model IEnumerable<CRMEsar.Models.ViewModels.CrudEntidades.TiposDocumentos.TiposDocumentosTablaVM>

@{
    ViewData["Title"] = "Lista de Tipos de Documentos";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-8">
            <h2 class="text-primary"> Lista de Tipos de Documentos</h2>
        </div>
        <div class="col-4 text-right">
            <a asp-action="Create" class="btn btn-primary" style="background:#1B75BB ; color:white;border:none"><i class="bi bi-plus-circle-fill"></i>&nbsp; Agregar Tipo de Documento</a>
        </div>
    </div>
    <br />
    <br />
    @if (TempData["RespuestaOperacion"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["RespuestaOperacion"]
        </div>
    }
    <div class="table-responsive">
        <table id="TblContenido" class="table table-striped table-bordered" style="width:100%">
            <thead>
                <tr>
                    <th> Nombre </th>
                    <th> Abreviatura </th>
                    <th> Pais </th>
                    <th> Estado </th>
                    <th> Acciones </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var modulos in Model)
                {
                    <tr>
                        <td>@modulos.TipoDocumento</td>
                        <td>@modulos.Abreviatura</td>
                        <td>@modulos.Pais</td>
                        <td>@modulos.Estado</td>
                        <td>
                            <a asp-route-id="@modulos.TipoDocumentoIdEncriptado" asp-action="Edit" class="btn btn-success text-white" style="background:#C63D96 ; color:white;border:none;cursor:pointer; width:140px;">
                                <i class="far fa-edit"></i> Editar
                            </a>
                            &nbsp;
                            <a href="javascript:void(0)"
                               class="btn btn-danger text-white btn-eliminar"
                               data-id="@modulos.TipoDocumentoIdEncriptado"
                               data-url="@Url.Action("Delete", "TiposDocumentos", new { area = "Panel" })"
                               style="background:#EE3A4F; border:none; width:140px;">
                                <i class="far fa-trash-alt"></i> Borrar
                            </a>
                        </td>
                        <form id="formEliminar" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" id="idEliminar" />
                        </form>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@section Scripts {
    <script src="~/js/Maestros/dataTableGenerico.js"></script>
    <script src="~/js/Maestros/SweetAlertEliminar.js"></script>

}