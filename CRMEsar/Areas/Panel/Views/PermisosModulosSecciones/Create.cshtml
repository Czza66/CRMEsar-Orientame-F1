@model CRMEsar.Models.ViewModels.CrudEntidades.PermisosModulosSecciones.PermisosModulosSeccionesCrearEditarVM

@{
    ViewData["Title"] = "Crear permiso";
}
<br />
<h3 class="text-center">Crear un nuevo permiso</h3>

<form method="POST" asp-action="Create">
    <div class="container p-4 ">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <div class="mb-3">
            <label asp-for="RolId" class="form-label">Rol para el permiso</label>
            @Html.DropDownListFor(c => c.RolId, Model.ListaRoles, "-- Selecciona un rol --", new { @class = "form-control" })
            <span asp-validation-for="RolId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Temporal" class="form-label">¿Permiso temporal?</label>
            <select asp-for="Temporal" class="form-select">
                <option value="false">No</option>
                <option value="true">Sí</option>
            </select>
            <span asp-validation-for="Temporal" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="FechaInicio" class="form-label"></label>
            <input asp-for="FechaInicio" type="datetime" class="form-control" placeholder="Fecha de inicio del permiso" />
            <span asp-validation-for="FechaInicio" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="FechaFin" class="form-label"></label>
            <input asp-for="FechaFin" type="datetime" class="form-control" placeholder="Fecha de finalizacion del permiso" />
            <span asp-validation-for="FechaFin" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="ModuloId" class="form-label">Modulo</label>
            @Html.DropDownListFor(c => c.ModuloId, Model.ListaModulos, "-- Selecciona un módulo --", new { @class = "form-control" })
            <span asp-validation-for="ModuloId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="SeccionId" class="form-label">Seccion</label>
            @Html.DropDownListFor(c => c.SeccionId, Model.ListaSecciones, "-- Selecciona una sección --", new { @class = "form-control" })
            <span asp-validation-for="SeccionId" class="text-danger"></span>
        </div>

        <div class="mt-4">
            <partial name="_VistaCrearVolver" />
        </div>
    </div>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const ddlRol = document.getElementById("RolId");
            const ddlModulo = document.getElementById("ModuloId");
            const ddlSeccion = document.getElementById("SeccionId");

            function resetSecciones(msg = "-- Selecciona una sección --") {
                ddlSeccion.innerHTML = "";
                const opt = document.createElement("option");
                opt.value = "";
                opt.textContent = msg;
                ddlSeccion.appendChild(opt);
                ddlSeccion.disabled = true;
            }

            async function cargarSecciones() {
                const roleId = ddlRol.value;
                const moduloId = ddlModulo.value;

                resetSecciones("-- Cargando secciones... --");

                if (!roleId || !moduloId) {
                    resetSecciones("-- Selecciona rol y módulo --");
                    return;
                }

                const url = `@Url.Action("GetSeccionesDisponibles", "PermisosModulosSecciones")?moduloId=${moduloId}&roleId=${roleId}`;

                try {
                    const res = await fetch(url);
                    if (!res.ok) throw new Error("HTTP " + res.status);

                    const data = await res.json();

                    ddlSeccion.innerHTML = "";
                    const placeholder = document.createElement("option");
                    placeholder.value = "";
                    placeholder.textContent = "-- Selecciona una sección --";
                    ddlSeccion.appendChild(placeholder);

                    if (!data || data.length === 0) {
                        const opt = document.createElement("option");
                        opt.value = "";
                        opt.textContent = "No hay secciones disponibles";
                        ddlSeccion.appendChild(opt);
                        ddlSeccion.disabled = true;
                        return;
                    }

                    data.forEach(x => {
                        const opt = document.createElement("option");
                        opt.value = x.value;
                        opt.textContent = x.text;
                        ddlSeccion.appendChild(opt);
                    });

                    ddlSeccion.disabled = false;

                } catch (e) {
                    console.error("Error cargando secciones:", e);
                    resetSecciones("-- Error cargando secciones --");
                }
            }

            // Inicial
            resetSecciones("-- Selecciona rol y módulo --");

            // Cuando cambien Rol o Módulo
            ddlRol.addEventListener("change", cargarSecciones);
            ddlModulo.addEventListener("change", cargarSecciones);
        });
    </script>
}
