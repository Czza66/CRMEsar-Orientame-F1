@model CRMEsar.Models.ViewModels.CrudEntidades.Cargos.CargosAgregarEditarVM

@{
    ViewData["Title"] = "Editar cargo";
}
<br />
<h3 class="text-center">Editar un cargo</h3>

<form method="POST" asp-action="Edit">
    <input type="hidden" asp-for="CargoId" />
    <div class="container p-4 ">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Cargo" class="form-label"></label>
            <input asp-for="Cargo" type="text" class="form-control" placeholder="Nombre del Cargo" />
            <span asp-validation-for="Cargo" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Abreviatura" class="form-label"></label>
            <input asp-for="Abreviatura" type="text" class="form-control" placeholder="Abreviatura del cargo" />
            <span asp-validation-for="Abreviatura" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="EstadoId" class="form-label">Estado del modulo</label>
            @Html.DropDownListFor(c => c.EstadoId, Model.ListaEstados, new { @class = "form-control" })
            <span asp-validation-for="EstadoId" class="text-danger"></span>
        </div>
        <div class="mt-4">
            <partial name="_VistaEditarVolver" />
        </div>
    </div>
</form>
@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}
