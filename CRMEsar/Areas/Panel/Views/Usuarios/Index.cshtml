@model IEnumerable<CRMEsar.Models.ViewModels.CrudEntidades.Usuarios.UsuariosTablaVM>

@{
    ViewData["Title"] = "Lista de usuarios";
}

<div class="container-fluid px-4 mt-4">
    <div class="row">
        <div class="col-8">
            <h2 class="text-primary"> Lista de Usuarias</h2>
        </div>
        <div class="col-4 text-right">
            <a asp-action="Create" class="btn btn-primary" style="background:#1B75BB ; color:white;border:none"><i class="bi bi-plus-circle-fill"></i>&nbsp; Agregar una Usuaria</a>
        </div>
    </div>
    <br />
    <br />
    @if (TempData["RespuestaOperacion"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["RespuestaOperacion"]
        </div>
    }
    <div class="table-responsive">
        <table id="TblContenido"
               class="table table-striped table-bordered align-middle nowrap"
               style="width:100%">
            <thead>
                <tr>
                    <th> Nombre </th>
                    <th> Correo </th>
                    <th> Identificación </th>
                    <th> Tipo de usuaria </th>
                    <th> Cargo </th>
                    <th> Ciudad </th>
                    <th> Género </th>
                    <th> Estado </th>
                    <th> Última modificación </th>
                    <th> Acciones </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var User in Model)
                {
                    <tr>
                        <td>@(User.NombreCompleto ?? "No registra Nombre completo")</td>
                        <td>@(User.correo ?? "N/A")</td>
                        <td>@(User.NumeroDocumento ?? "N/A")</td>
                        <td>@(User.TipoUsuario ?? "N/A")</td>
                        <td>@(User.Cargo ?? "N/A")</td>
                        <td>@(string.IsNullOrWhiteSpace(User.Ciudad) ? "N/A" : User.Ciudad)</td>
                        <td>@(User.Sexo ?? "N/A")</td>
                        <td>@(User.Estado ?? "N/A")</td>
                        <td>@User.FechaModificacion.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a asp-route-id="@User.UsuarioIdEncriptado" asp-action="Edit" class="btn btn-success text-white" style="background:#C63D96 ; color:white;border:none;cursor:pointer; width:140px;">
                                <i class="far fa-edit"></i> Editar
                            </a>
                            &nbsp;
                            <a href="javascript:void(0)"
                               class="btn btn-danger text-white btn-eliminar"
                               data-id="@User.UsuarioIdEncriptado"
                               data-url="@Url.Action("Delete", "Usuarios", new { area = "Panel" })"
                               style="background:#EE3A4F; border:none; width:140px;">
                                <i class="far fa-trash-alt"></i> Borrar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <form id="formEliminar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="idEliminar" />
        </form>
    </div>
</div>
@section Scripts {
    <script src="~/js/Maestros/dataTableGenerico.js"></script>
    <script src="~/js/Maestros/SweetAlertEliminar.js"></script>

}