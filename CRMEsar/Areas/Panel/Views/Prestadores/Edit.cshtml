@model CRMEsar.Models.ViewModels.CrudEntidades.Prestadores.PrestadoresEditarVM

@{
    ViewData["Title"] = "Editar prestador";
}

<br />
<h3 class="text-center">Editar un prestador</h3>

<form method="POST" asp-action="Create">
    <div class="container p-4">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row g-3">
            <!-- DATOS USUARIO (READONLY) -->
            <div class="col-xl-3 col-lg-4 col-md-6 col-12">
                <label class="form-label">Nombre completo</label>
                <input asp-for="NombreCompleto" type="text" class="form-control"  readonly/>

            </div>

            <div class="col-xl-3 col-lg-4 col-md-6 col-12">
                <label class="form-label">Correo</label>
                <input asp-for="Correo" type="text" class="form-control" readonly />

            </div>

            <div class="col-xl-3 col-lg-4 col-md-6 col-12">
                <label class="form-label">Ciudad</label>
                <input asp-for="Ciudad" type="text" class="form-control"  readonly />

            </div>

            <div class="col-xl-3 col-lg-4 col-md-6 col-12">
                <label class="form-label">Pais</label>
                <input asp-for="Pais" type="text" class="form-control"  readonly />

            </div>
        </div>
        <hr />
        <div class="mb-3">
            <label asp-for="TipoPrestador" class="form-label">Tipo de prestadora</label>
            <select asp-for="TipoPrestador"
                    asp-items="Model.ListaTipoPrestador"
                    class="form-control">
            </select>
            <span asp-validation-for="TipoPrestador" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="TipoServicio" class="form-label"></label>
            <input asp-for="TipoServicio" type="text" class="form-control" placeholder="Tipo de servicio" />
            <span asp-validation-for="Profesion" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Profesion" class="form-label"></label>
            <input asp-for="Profesion" type="text" class="form-control" placeholder="Profesion de la prestadora" />
            <span asp-validation-for="Profesion" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="RecomendadoPor" class="form-label"></label>
            <input asp-for="RecomendadoPor" type="text" class="form-control" placeholder="¿Fue recomendada por alguien?" />
            <span asp-validation-for="RecomendadoPor" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Telefono" class="form-label"></label>
            <input asp-for="Telefono" type="text" class="form-control" placeholder="Telefono" />
            <span asp-validation-for="Telefono" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Celular" class="form-label"></label>
            <input asp-for="Celular" type="text" class="form-control" placeholder="Celular" />
            <span asp-validation-for="Celular" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Orientador" class="form-label">¿Es Orientadora?</label>
            <select asp-for="Orientador" class="form-control">
                <option value="false">No</option>
                <option value="true">Sí</option>
            </select>
            <span asp-validation-for="Orientador" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="PermiteILVE" class="form-label">¿Permite IVE?</label>
            <select asp-for="PermiteILVE" class="form-control">
                <option value="false">No</option>
                <option value="true">Sí</option>
            </select>
            <span asp-validation-for="PermiteILVE" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="EstadoId" class="form-label">Estado de la prestadora</label>
            @Html.DropDownListFor(c => c.EstadoId, Model.ListaEstados, new { @class = "form-control" })
            <span asp-validation-for="EstadoId" class="text-danger"></span>
        </div>

        <!-- CAMPOS DEL PRESTADOR -->
        <div class="mt-4">
                <partial name="_VistaEditarVolver" />
        </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
