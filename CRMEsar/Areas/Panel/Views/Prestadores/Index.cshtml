@model IEnumerable<CRMEsar.Models.ViewModels.CrudEntidades.Prestadores.PrestadoresTablaVM>

@{
    ViewData["Title"] = "Lista de prestadores";
}

<div class="container-fluid px-4 mt-4">
    <div class="row">
        <div class="col-8">
            <h2 class="text-primary"> Lista de prestadoras</h2>
        </div>
        <div class="col-4 text-right">
            <a asp-action="Create" class="btn btn-primary" style="background:#1B75BB ; color:white;border:none"><i class="bi bi-plus-circle-fill"></i>&nbsp; Agregar una Prestadora</a>
        </div>
    </div>
    <br />
    <br />
    @if (TempData["RespuestaOperacion"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["RespuestaOperacion"]
        </div>
    }
    <div class="table-responsive">
        <table id="TblContenido" class="table table-striped table-bordered align-middle nowrap"
               style="width:100%">
            <thead>
                <tr>
                    <th> Nombre </th>
                    <th> Correo </th>
                    <th> Profesión </th>
                    <th> Tipo de Servicio </th>
                    <th> Tipo de Prestadora </th>
                    <th> Estado </th>
                    <th> Acciones </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prestadores in Model)
                {
                    <tr>
                        <td>@prestadores.NombreCompleto</td>
                        <td>@prestadores.Correo</td>
                        <td>@prestadores.Profesion</td>
                        <td>@prestadores.TipoServicio</td>
                        <td>@prestadores.TipoPrestador</td>
                        <td>@prestadores.Estado</td>
                        <td>
                            <a asp-route-id="@prestadores.PrestadorIdEncriptado" asp-action="Edit" class="btn btn-success text-white" style="background:#C63D96 ; color:white;border:none;cursor:pointer; width:140px;">
                                <i class="far fa-edit"></i> Editar
                            </a>
                            &nbsp;
                            <a href="javascript:void(0)"
                               class="btn btn-danger text-white btn-eliminar"
                               data-id="@prestadores.PrestadorIdEncriptado"
                               data-url="@Url.Action("Delete", "Prestadores", new { area = "Panel" })"
                               style="background:#EE3A4F; border:none; width:140px;">
                                <i class="far fa-trash-alt"></i> Borrar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <form id="formEliminar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="idEliminar" />
        </form>
    </div>
</div>
@section Scripts {
    <script src="~/js/Maestros/dataTableGenerico.js"></script>
    <script src="~/js/Maestros/SweetAlertEliminar.js"></script>
}