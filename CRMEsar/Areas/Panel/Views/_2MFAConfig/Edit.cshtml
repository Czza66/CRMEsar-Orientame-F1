@model CRMEsar.Models.ViewModels.CrudEntidades._2MFAConfig._2MFAVM

@{
    ViewData["Title"] = "Editar 2MFA";
}
<br />
<h3 class="text-center">Editar configuracion 2MFA</h3>
@if (TempData["RespuestaOperacion"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["RespuestaOperacion"]
    </div>
}

<form method="POST" asp-action="Edit">
    <input type="hidden" asp-for="IdEncriptadoString" />
    <input type="hidden" asp-for="IdEncriptadoValue" />
    <div class="container p-4 ">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label"> Cantidad de tiempo para volver a solicitar 2FA </label>
            <input asp-for="ValueInt" type="number" class="form-control" placeholder="0" />
            <span asp-validation-for="ValueInt" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label"> Unidad de tiempo para solicitar nuevamente el 2FA </label>
            <select asp-for="ValueString"
                    class="form-control form-select-sm">
                <option value="weeks"> Semanas </option>
                <option value="months"> Meses </option>
            </select>
        </div>

        <div class="row">
            <div class="col">
                <button type="submit" class="btn btn-primary form-control"> Editar Registro</button>
            </div>
            &nbsp;
            <div class="col">
                <a asp-area="Panel" asp-controller="Home" asp-action="Index" class="btn btn-success form-control"> Volver atrás</a>
            </div>
        </div>
    </div>
</form>
@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}
